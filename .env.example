# HeliosHash DAO Environment Configuration
# Copy this file to .env and fill in your actual values

# Internet Computer Canister IDs
CANISTER_ID_HHDAO=your-canister-id-here
CANISTER_ID_HHDAO_DAO=your-dao-canister-id-here

# Next.js Configuration
NEXT_PUBLIC_IC_HOST=http://localhost:4943
NEXT_PUBLIC_DFX_NETWORK=local

# Development Configuration
NODE_ENV=development

# Payment Gateway Configuration (if needed)
RAZORPAY_KEY_ID=your-razorpay-key-here
RAZORPAY_KEY_SECRET=your-razorpay-secret-here

# Identity Verification (if needed)
ONFIDO_TOKEN=your-onfido-token-here
PROJECT_ID=your-project-id-here

# Add other environment variables as needed
# Never commit the actual .env file with real values
