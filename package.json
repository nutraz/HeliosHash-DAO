{
  "name": "nextjs_tailwind_shadcn_ts",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "NODE_ENV=development PORT=3001 HOSTNAME=0.0.0.0 npx tsx server.ts 2>&1 | tee dev.log",
    "dev:health": "pnpm dev & DEV_PID=$!; sleep 3; pnpm health || true; wait $DEV_PID",
    "dev:nodemon": "nodemon --exec \"npx tsx server.ts\" --watch server.ts --watch src --ext ts,tsx,js,jsx 2>&1 | tee dev.log",
    "dev:next": "next dev",
    "health": "bash scripts/health-check.sh",
    "mobile-dev": "bash scripts/mobile-dev.sh",
    "status": "curl -s http://localhost:${PORT:-3001}/api/status | jq . || curl -s http://localhost:${PORT:-3001}/api/status",
    "compare:external": "bash scripts/compare-external.sh",
    "build": "next build",
    "start": "NODE_ENV=production tsx server.ts 2>&1 | tee server.log",
    "lint": "next lint",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "test:coverage": "vitest run --coverage",
    "test:jest": "jest",
    "test:jest:watch": "jest --watch",
    "test:jest:coverage": "jest --coverage",
    "test:run": "vitest run",
    "test:ui": "vitest --ui",
    "test:all": "pnpm test:run && pnpm test:e2e && pnpm test:canister",
    "test:canister": "./canisters/test-runner/run-tests.sh",
    "test:smoke": "playwright test --grep=\"@smoke\"",
    "test:integration": "playwright test --grep=\"@integration\" && pnpm test:canister",
    "test:performance": "playwright test --project=performance --grep=\"@performance\"",
    "test:security": "playwright test --project=security --grep=\"@security\"",
    "test:categories": "echo 'Available test categories:' && echo '  @smoke - Critical path tests' && echo '  @integration - Canister integration tests' && echo '  @performance - Load and performance tests' && echo '  @security - Security-focused tests'",
    "test:mobile": "playwright test --project=mobile-chrome --project=mobile-safari",
    "test:e2e:mobile": "playwright test --project=mobile-chrome --project=mobile-safari --project=tablet-chrome",
    "dev:e2e": "NODE_ENV=development tsx server.ts",
    "test:e2e": "playwright test",
    "qr": "node scripts/display-qr.js",
    "qr:web": "node scripts/display-qr.js && echo '\n🌐 Web QR Code: http://localhost:3000/qr'",
    "mobile": "node mobile_hhdao_server.js",
    "mobile:qr": "node generate_mobile_qr.js",
    "mobile:test": "node mobile_test_server.js",
    "pilot:launch": "python3 launch_pilot.py",
    "pilot:status": "node test_current_proximity.js",
    "compute:pivot": "dfx canister call compute pivotComputeMode '(\"ai\")'",
    "ussd:server": "node mobile_hhdao_server.js",
    "thermal:simulate": "python3 scripts/thermal_simulation.py",
    "db:push": "prisma db push",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:reset": "prisma migrate reset",
    "docker:dev": "docker-compose up hhdao-dev",
    "docker:dev:build": "docker-compose build hhdao-dev && docker-compose up hhdao-dev",
    "docker:prod": "docker-compose --profile production up hhdao-prod",
    "docker:dfx": "docker-compose --profile dfx up dfx-network",
    "docker:all": "docker-compose --profile production --profile dfx up",
    "docker:down": "docker-compose down",
    "docker:clean": "docker-compose down -v && docker system prune -f",
    "scan:currency": "tsx scripts/currency-scan.ts",
    "validate:services": "tsx scripts/validate-services.ts",
    "prepare": "husky install",
    "build:canisters": "dfx build",
    "deploy:enhanced": "./scripts/enhanced-deploy.sh",
    "deploy:staging": "./scripts/enhanced-deploy.sh staging",
    "deploy:production": "./scripts/enhanced-deploy.sh production",
    "deploy:mobile": "./scripts/enhanced-deploy.sh mobile"
  },
