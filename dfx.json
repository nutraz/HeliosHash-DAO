{
  "canisters": {
    "hhdao": {
      "main": "canisters/hhdao/src/main.mo",
      "type": "motoko"
    },
    "hhdao_frontend": {
      "dependencies": [
        "hhdao"
      ],
      "frontend": {
        "entrypoint": "public/index.html"
      },
      "source": [
        "public/",
        "dist/"
      ],
      "type": "assets"
    },
    "hhdao_dao": {
      "main": "canisters/dao/main.mo",
      "type": "motoko"
    },
    "hhdao_identity": {
      "main": "canisters/identity/main.mo",
      "type": "motoko"
    },
    "hhdao_telemetry": {
      "main": "canisters/telemetry/main.mo",
      "type": "motoko"
    },
    "hhdao_documents": {
      "main": "canisters/documents/main.mo",
      "type": "motoko"
    }
  },
  "defaults": {
    "build": {
      "packtool": ""
    }
  },
  "networks": {
    "local": {
      "bind": "127.0.0.1:8000"
    },
    "ic": {
      "type": "ephemeral"
    }
  },
  "version": 1
}
