{
  "canisters": {
    "hhdao_dao": {
      "main": "canisters/dao/main.mo",
      "type": "motoko"
    },
    "hhdao_identity": {
      "main": "canisters/identity/main.mo",
      "type": "motoko"
    },
    "hhdao_telemetry": {
      "main": "canisters/telemetry/main.mo",
      "type": "motoko"
    },
    "hhdao_documents": {
      "main": "canisters/documents/main.mo",
      "type": "motoko"
    },
    "hhdao_dispute_resolution": {
      "main": "canisters/dispute-resolution/main.mo",
      "type": "motoko"
    },
    "hhdao_treasury": {
      "main": "canisters/treasury/main.mo",
      "type": "motoko"
    },
    "hhdao_meeting_management": {
      "main": "canisters/meeting-management/main.mo",
      "type": "motoko"
    },
    "hhdao": {
      "main": "canisters/hhdao/src/main.mo",
      "type": "motoko",
      "dependencies": ["hhdao_dao", "hhdao_identity", "hhdao_telemetry", "hhdao_documents"]
    },
    "hhdao_frontend": {
      "dependencies": [
        "hhdao",
        "hhdao_dao",
        "hhdao_identity",
        "hhdao_telemetry",
        "hhdao_documents"
      ],
      "frontend": {
        "entrypoint": "public/index.html"
      },
      "source": ["public/"],
      "type": "assets"
    }
  },
  "defaults": {
    "build": {
      "packtool": ""
    }
  },
  "networks": {
    "local": {
      "bind": "127.0.0.1:8000"
    },
    "ic": {
      "type": "ephemeral"
    }
  },
  "version": 1
}
