{
  "name": "helioshash-dao",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "pnpm exec tsc && vite build",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:canister": "cd canisters/test-runner && ./run-tests.sh",
    "test:e2e": "pnpm exec playwright test --workers=4",
    "test:all": "pnpm test:run && pnpm test:canister && pnpm test:e2e",
    "check-structure": "./scripts/check-structure.sh",
    "build:all": "pnpm build:canister && pnpm build",
    "build:canister": "dfx deploy hhdao_dao",
    "clean": "dfx stop && rm -rf .dfx dist node_modules/.vite"
  },
  "dependencies": {
    "@dfinity/agent": "^3.2.4",
    "@dfinity/candid": "^3.2.4",
    "@dfinity/principal": "^3.2.4",
    "@types/react-router-dom": "^5.3.3",
    "@web3modal/ethereum": "^2.7.1",
    "@web3modal/react": "^2.7.1",
    "framer-motion": "^12.23.12",
    "i18next": "^25.5.2",
    "lucide-react": "^0.543.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "15.7.3",
    "react-router-dom": "^6.23.1",
    "viem": "^2.0.0",
    "wagmi": "^2.17.1"
  },
  "devDependencies": {
    "@babel/plugin-transform-runtime": "^7.28.3",
    "@babel/preset-env": "^7.28.3",
    "@babel/preset-react": "^7.27.1",
    "@playwright/test": "^1.55.0",
    "@tailwindcss/postcss": "^4.1.13",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.3.1",
    "@types/react": "^18.3.24",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^4.3.1",
    "@vitest/coverage-v8": "^3.2.4",
    "@vitest/ui": "^3.2.4",
    "autoprefixer": "^10.4.0",
    "babel-jest": "^30.1.2",
    "cypress": "^15.1.0",
    "eslint": "^9.35.0",
    "jest": "^30.1.3",
    "jest-environment-jsdom": "^30.1.2",
    "jsdom": "^27.0.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^4.1.12",
    "typescript": "^5.9.2",
    "vite": "^5.4.8",
    "vitest": "^3.2.4"
  }
}
