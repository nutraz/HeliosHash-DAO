export function AuthProvider({ children }: { children: ReactNode }) {
  const [user, setUser] = useState<User | null>(null);
  const [isLoading, setIsLoading] = useState(true);

  // Initialize with mock data - replace with actual auth logic
  useEffect(() => {
    const initAuth = async () => {
      setIsLoading(true);
      
      // Check if user is already logged in (localStorage for demo)
      const savedUserId = localStorage.getItem('hhdao-user-id');
      if (savedUserId && mockUsers[savedUserId]) {
        setUser(mockUsers[savedUserId]);
      }
      
      setIsLoading(false);
    };

    initAuth();
  }, []);

  const hasRole = (role: UserRole): boolean => {
    if (!user) return false;
    return user.role === role || user.secondaryRoles.includes(role);
  };

  const login = async (credentials: any) => {
    setIsLoading(true);
    
    // Mock login logic - replace with actual canister calls
    const { userType = 'community-user' } = credentials;
    const userData = mockUsers[userType];
    
    if (userData) {
      setUser(userData);
      localStorage.setItem('hhdao-user-id', userType);
    }
    
    setIsLoading(false);
  };

  const logout = () => {
    setUser(null);
    localStorage.removeItem('hhdao-user-id');
  };

  const updateProfile = async (updates: Partial<User>) => {
    if (!user) return;
    
    const updatedUser = { ...user, ...updates };
    setUser(updatedUser);
    
    // Update mock data
    const userId = Object.keys(mockUsers).find(key => mockUsers[key].id === user.id);
    if (userId) {
      mockUsers[userId] = updatedUser;
    }
  };

  const setUserRole = async (role: UserRole) => {
    await updateProfile({ role });
  };

  const value: AuthContextType = {
    user,
    isLoading,
    isAuthenticated: !!user,
    hasRole,
    login,
    logout,
    updateProfile,
    setUserRole
  };

  return (
    <AuthContext.Provider value={value}>
      {children}
    </AuthContext.Provider>
  );
}

export function useAuthContext() {
  const context = useContext(AuthContext);
  if (context === undefined) {
    throw new Error('useAuthContext must be used within an AuthProvider');
  }
  return context;
}

// Legacy hook for backward compatibility
export function useAuth() {
  return useAuthContext();
}