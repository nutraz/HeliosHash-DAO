{
  "name": "nextjs_tailwind_shadcn_ts",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "NODE_ENV=development PORT=3001 HOSTNAME=0.0.0.0 npx tsx server.ts 2>&1 | tee dev.log",
    "dev:health": "pnpm dev & DEV_PID=$!; sleep 3; pnpm health || true; wait $DEV_PID",
    "dev:nodemon": "nodemon --exec \"npx tsx server.ts\" --watch server.ts --watch src --ext ts,tsx,js,jsx 2>&1 | tee dev.log",
    "dev:next": "next dev",
    "health": "bash scripts/health-check.sh",
    "mobile-dev": "bash scripts/mobile-dev.sh",
    "mobile": "bash scripts/mobile-dev.sh",
    "status": "curl -s http://localhost:${PORT:-3001}/api/status | jq . || curl -s http://localhost:${PORT:-3001}/api/status",
    "compare:external": "bash scripts/compare-external.sh",
    "build": "next build",
    "start": "NODE_ENV=production tsx server.ts 2>&1 | tee server.log",
    "lint": "next lint",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:vitest": "vitest run",
    "test:vitest:ui": "vitest --ui",
    "test:run": "vitest run",
    "dev:e2e": "NODE_ENV=development tsx server.ts",
    "test:e2e": "playwright test",
    "qr": "node scripts/display-qr.js",
    "qr:web": "node scripts/display-qr.js && echo '\n🌐 Web QR Code: http://localhost:3000/qr'",
    "db:push": "prisma db push",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:reset": "prisma migrate reset",
    "docker:dev": "docker-compose up hhdao-dev",
    "docker:dev:build": "docker-compose build hhdao-dev && docker-compose up hhdao-dev",
    "docker:prod": "docker-compose --profile production up hhdao-prod",
    "docker:dfx": "docker-compose --profile dfx up dfx-network",
    "docker:all": "docker-compose --profile production --profile dfx up",
    "docker:down": "docker-compose down",
    "docker:clean": "docker-compose down -v && docker system prune -f",
    "scan:currency": "tsx scripts/currency-scan.ts",
    "validate:services": "tsx scripts/validate-services.ts",
    "prepare": "husky install",
    "build:canisters": "dfx build",
    "test:canister": "dfx build && echo 'Canisters built successfully'"
  },
